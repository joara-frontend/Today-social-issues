# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/my-app/node_modules
/my-app/.pnp
my-app/.pnp.*
my-app/.yarn/*
!my-app/.yarn/patches
!my-app/.yarn/plugins
!my-app/.yarn/releases
!my-app/.yarn/versions

# testing
/my-app/coverage

# next.js
/my-app/.next/
/my-app/out/

# production
/my-app/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI
my-app/**/AGENTS.md
my-app/**/CLAUDE.md
/.claude
